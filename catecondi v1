/*
|--------------------------------------------------------------------------
| Pattern 4: Brand + category → 'lower'
|--------------------------------------------------------------------------
*/
foreach ([
    'items-bag-louisvuitton' => ['louisvuitton', 'bag'],
] as $key => [$brand, $category]) {
    $conditions[$key] = function ($path) use ($brand, $category) {
        $info = get_data('item-info', $path);

        if (
            ($info['brand_key'] ?? null) === $brand
            && ($info['category_key'] ?? null) === $category
        ) {
            return 'lower';
        }
    };
}

/*
|--------------------------------------------------------------------------
| Pattern 5: Category → position-based ('upper' if category_top, else 'lower')
|--------------------------------------------------------------------------
*/
foreach ([
    'brands-bag'          => 'bag',
    'brands-brandjewelry' => 'brandjewelry',
    'brands-wallet'       => 'wallet',
    'brands-apparel'      => 'apparel',
    'brands-gold'         => 'gold',
    'brands-watch'        => 'watch',
    'brands-gem'          => 'gem',
] as $key => $category) {
    $conditions[$key] = function ($path) use ($category) {
        $info = get_data('item-info', $path);

        if (($info['category_key'] ?? null) === $category) {
            return ($info['page_type'] ?? null) === Page_Type::category_top->name
                ? 'upper'
                : 'lower';
        }
    };
}

return $conditions;
