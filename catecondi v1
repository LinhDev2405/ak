<?php

$conditions = [];

/*
|--------------------------------------------------------------------------
| Pattern 1: Brand + category → 'upper'
| Matches when brand_key = brand AND (page is brand page OR category matches)
|--------------------------------------------------------------------------
*/
foreach ([
    'items-vancleefarpels-jewelry' => ['vancleefarpels', 'jewelry'],
    'items-hermes-bag'             => ['hermes',         'bag'],
    'items-hermes-wallet'          => ['hermes',         'wallet'],
    'items-cartier-jewelry'        => ['cartier',        'jewelry'],
    'items-cartier-bag'            => ['cartier',        'bag'],
    'items-cartier-watch'          => ['cartier',        'watch'],
    'items-gucci-bag'              => ['gucci',          'bag'],
    'items-chanel-bag'             => ['chanel',         'bag'],
    'items-chanel-watch'           => ['chanel',         'watch'],
    'items-dior-bag'               => ['dior',           'bag'],
    'items-dior-watch'             => ['dior',           'watch'],
    'items-tiffany-jewelry'        => ['tiffany',        'jewelry'],
    'items-harrywinston-jewelry'   => ['harrywinston',   'jewelry'],
    'items-harrywinston-watch'     => ['harrywinston',   'watch'],
    'items-piaget-jewelry'         => ['piaget',         'jewelry'],
    'items-piaget-watch'           => ['piaget',         'watch'],
    'items-fendi-bag'              => ['fendi',          'bag'],
    'items-bvlgari-jewelry'        => ['bvlgari',        'jewelry'],
    'items-bvlgari-watch'          => ['bvlgari',        'watch'],
    'items-loewe-bag'              => ['loewe',          'bag'],
] as $key => [$brand, $category]) {
    $conditions[$key] = function ($path) use ($brand, $category) {
        $info = get_data('item-info', $path);
        if (($info['brand_key'] ?? null) !== $brand) return null;

        if (
            ($info['page_type'] ?? null) === Page_Type::brand->name
            || ($info['category_key'] ?? null) === $category
        ) {
            return 'upper';
        }
    };
}

/*
|--------------------------------------------------------------------------
| Pattern 2: Brand + line_group → result
|--------------------------------------------------------------------------
*/
foreach ([
    'items-damier-louisvuitton'   => ['louisvuitton', 'damier',   'upper'],
    'items-monogram-louisvuitton' => ['louisvuitton', 'monogram', 'lower'],
] as $key => [$brand, $line_group, $result]) {
    $conditions[$key] = function ($path) use ($brand, $line_group, $result) {
        $info = get_data('item-info', $path);

        if (
            ($info['brand_key'] ?? null) === $brand
            && ($info['line_group_key'] ?? null) === $line_group
        ) {
            return $result;
        }
    };
}

